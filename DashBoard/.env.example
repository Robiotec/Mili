# Copia este archivo como .env y completa los valores sensibles.
# No subas .env al repositorio.

# Base de datos PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=dashboard
DB_USER=dashboarduser
DB_PASSWORD=
DB_MIN_SIZE=1
DB_MAX_SIZE=10
DB_TIMEOUT=10
DB_CONNECT_TIMEOUT=5
DB_BOOTSTRAP_ON_STARTUP=true
VEHICLE_TELEMETRY_CONFIG_TABLE=configuracion_mavlink

# Seed inicial
DEFAULT_SUPERADMIN_USERNAME=admin
DEFAULT_SUPERADMIN_PASSWORD=
DEFAULT_SUPERADMIN_EMAIL=admin@robiotec.local
DEFAULT_DEMO_ORG_NAME=ROBIOTEC DEMO
DEFAULT_DEMO_VEHICLE_UNIQUE_ID=DEMO-CAR-001
DEFAULT_DEMO_CAMERA_UNIQUE_ID=DEMO-CAM-001

# Seguridad
WEB_SESSION_COOKIE_NAME=robiotec_session
WEB_SESSION_SECRET=
WEB_SESSION_MAX_AGE_SECONDS=28800
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
PASSWORD_HASH_ITERATIONS=390000
PASSWORD_SALT_BYTES=16

# Web
WEB_HOST=0.0.0.0
WEB_PORT=8001
WEB_LOG_FILE=/home/robiotec/SVI/servicios/logs/dashboard.log
TELEMETRY_MAP_MIN_ZOOM=6
TELEMETRY_MAP_MAX_ZOOM=18
THUNDERFOREST_API_KEY=

# API Central y visor protegido
STREAM_API_HOST=127.0.0.1
STREAM_API_PORT=8004
STREAM_API_BASE_URL=http://127.0.0.1:8004
STREAM_API_USERNAME=
STREAM_API_PASSWORD=
STREAM_REQUEST_TIMEOUT=10
STREAM_VIEWER_MUTED=0
STREAM_NAME=CAM3
VIEWER_CACHE_MAX_AGE_SECONDS=86400

# MediaMTX
MEDIAMTX_HOST=
MEDIAMTX_WEBRTC_PORT=8989
MEDIAMTX_RTSP_PORT=8654
MEDIAMTX_HLS_PORT=8988
MEDIAMTX_RTMP_PORT=1936
MEDIAMTX_SRT_PORT=8991

# Telemetria, objetivos y aeronaves
GPS_API_BASE_URL=http://127.0.0.1:8004
API_TELEMETRY_DEFAULT_DRONE_ID=drone
TELEMETRY_REFRESH_SECONDS=1
DRONE_TRACKS_DIR=/home/robiotec/SVI/trayectorias
OPENSKY_DATA_FILE=/home/robiotec/SVI/opensky/opensky_data.json
AIRPLANES_API_URL=https://api.airplanes.live/v2/point/{lat}/{lon}/{radius}
AIRPLANES_REQUEST_TIMEOUT_SEC=8
AIRPLANES_VIEWPORT_RADIUS_NM=180
AIRPLANES_VIEWPORT_MAX_POINTS=9
OBJETIVOS_DIR=/home/robiotec/SVI/objetivos
OBJETIVO_API_BASE_URL=http://127.0.0.1:8004

# Capa ARCOM
ARCOM_ENABLED=false
ARCOM_GPKG_PATH=/home/robiotec/ARCOM/arcom_catastro.gpkg
ARCOM_MAX_FEATURES_PER_REQUEST=120
ARCOM_MIN_ZOOM=11

# Lectura remota de crops/placas
CROPS_SSH_HOST=
CROPS_SSH_USER=
CROPS_SSH_PORT=22
CROPS_SSH_KEY_PATH=
CROPS_REMOTE_MANIFEST_PATH=
CROPS_SSH_STRICT_HOST_KEY_CHECKING=accept-new
CROPS_CONNECT_TIMEOUT=10
CROPS_COMMAND_TIMEOUT=20
CROPS_MAX_RETRIES=2
CROPS_RETRY_DELAY=2
CROPS_MANIFEST_CACHE_TTL_SEC=30

# Variables heredadas opcionales
DJI_MQTT_BROKER=
DJI_MQTT_PORT=1883
WEB_ALWAYS_ON_CAMERAS=
