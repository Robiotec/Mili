# Copy this file to .env and fill in the values before running the app.

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=dashboard
DB_USER=dashboarduser
DB_PASSWORD=
DB_MIN_SIZE=1
DB_MAX_SIZE=10
DB_TIMEOUT=10
DB_CONNECT_TIMEOUT=5

# ============================================================
# API CENTRAL (Stream Protection) CONFIGURATION
# ============================================================
STREAM_API_HOST=127.0.0.1
STREAM_API_PORT=8004
STREAM_API_USERNAME=
STREAM_API_PASSWORD=
STREAM_API_BASE_URL=http://127.0.0.1:8004
STREAM_REQUEST_TIMEOUT=10
STREAM_VIEWER_MUTED=0
GPS_API_BASE_URL=http://127.0.0.1:8004
API_TELEMETRY_DEFAULT_DRONE_ID=drone
TELEMETRY_REFRESH_SECONDS=1
VEHICLE_TELEMETRY_CONFIG_TABLE=configuracion_mavlink
ARCOM_GPKG_PATH=/path/to/arcom_catastro.gpkg
ARCOM_MAX_FEATURES_PER_REQUEST=120
ARCOM_ENABLED=true
ARCOM_MIN_ZOOM=11
OPENSKY_DATA_FILE=/home/robiotec/SVI/opensky/opensky_data.json
OBJETIVOS_DIR=/home/robiotec/SVI/objetivos
OBJETIVO_API_BASE_URL=http://127.0.0.1:8004
WEB_LOG_FILE=/home/robiotec/SVI/servicios/logs/dashboard.log

# ============================================================
# MEDIAMTX PROTOCOL PORTS
# ============================================================
MEDIAMTX_HOST=
MEDIAMTX_WEBRTC_PORT=8989
MEDIAMTX_RTSP_PORT=8654
MEDIAMTX_HLS_PORT=8988
MEDIAMTX_RTMP_PORT=1936
MEDIAMTX_SRT_PORT=8991

# ============================================================
# WEB APPLICATION CONFIGURATION
# ============================================================
WEB_SESSION_COOKIE_NAME=robiotec_session
WEB_SESSION_SECRET=
JWT_SECRET=
WEB_SESSION_MAX_AGE_SECONDS=28800
WEB_HOST=0.0.0.0
WEB_PORT=8001
TELEMETRY_MAP_MIN_ZOOM=6
TELEMETRY_MAP_MAX_ZOOM=18

# ============================================================
# VIEWER CACHE CONFIGURATION
# ============================================================
VIEWER_CACHE_MAX_AGE_SECONDS=86400

# ============================================================
# DJI TELEMETRY MQTT CONFIGURATION
# ============================================================
DJI_MQTT_BROKER=
DJI_MQTT_PORT=1883

# ============================================================
# CROPS SSH CONFIGURATION
# ============================================================
CROPS_SSH_HOST=
CROPS_SSH_USER=
CROPS_SSH_PORT=22
CROPS_SSH_KEY_PATH=
CROPS_REMOTE_MANIFEST_PATH=
