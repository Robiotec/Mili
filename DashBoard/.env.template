# ============================================================
# ROBIOTEC DASHBOARD ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================
# This file documents all environment variables used by the
# Robiotec Dashboard application.
# 
# Copy this file to .env and fill in your environment-specific values:
#   cp .env.template .env
#
# Do NOT commit the .env file to version control as it contains
# sensitive information like passwords and API credentials.
#
# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# PostgreSQL host (IP or hostname)
# Default: 127.0.0.1
DB_HOST=127.0.0.1

# PostgreSQL port
# Default: 5432
DB_PORT=5432

# Database name
# Default: vigilancia
DB_NAME=vigilancia

# Database user
# Default: pedro
DB_USER=pedro

# Database password (sensitive)
# Default: 123456
DB_PASSWORD=123456

# Minimum number of database connections in pool
# Default: 1
DB_MIN_SIZE=1

# Maximum number of database connections in pool
# Default: 10
DB_MAX_SIZE=10

# Connection timeout in seconds
# Default: 10
DB_TIMEOUT=10

# Connection establishment timeout in seconds
# Default: 5
DB_CONNECT_TIMEOUT=5

# ============================================================
# API CENTRAL (Stream Protection) CONFIGURATION
# ============================================================

# API Central hostname or IP
# Default: 127.0.0.1
STREAM_API_HOST=127.0.0.1

# API Central port
# Default: 8004
STREAM_API_PORT=8004

# API Central base URL (overrides auto-constructed URL if set)
# If empty, will be constructed as: http://{STREAM_API_HOST}:{STREAM_API_PORT}
# Default: (empty)
STREAM_API_BASE_URL=

# API Central username for authentication
# Default: admin
STREAM_API_USERNAME=admin

# API Central password for authentication (sensitive)
# Default: Robiotec@2025
STREAM_API_PASSWORD=Robiotec@2025

# Default stream name to request from API Central
# Default: CAM3
STREAM_NAME=CAM3

# Timeout for API Central requests in seconds
# Default: 10
STREAM_REQUEST_TIMEOUT=10

# Default: auto-play viewer with muted audio (0=false, 1=true)
# Default: 0
STREAM_VIEWER_MUTED=0

# Base URL for GPS telemetry polling (API CENTRAL)
# Dashboard polls telemetry by ID using /telemetry/{id}/gps
# Default: http://127.0.0.1:8004
GPS_API_BASE_URL=http://127.0.0.1:8004

# Default API device id for drones when telemetry_mode=api and id is empty
# Default: drone
API_TELEMETRY_DEFAULT_DRONE_ID=drone

# Global telemetry refresh interval in seconds.
# Used by both the API telemetry bridge polling loop and the frontend map refresh.
# Default: 1
TELEMETRY_REFRESH_SECONDS=1

# Bootstrap the minimum seed data at startup.
# Default: true
DB_BOOTSTRAP_ON_STARTUP=true

# Initial superadmin seed.
# Default username: admin
DEFAULT_SUPERADMIN_USERNAME=admin
DEFAULT_SUPERADMIN_PASSWORD=Robiotec@2026
DEFAULT_SUPERADMIN_EMAIL=admin@robiotec.local

# Initial demo records.
DEFAULT_DEMO_ORG_NAME=ROBIOTEC DEMO
DEFAULT_DEMO_VEHICLE_UNIQUE_ID=DEMO-CAR-001
DEFAULT_DEMO_CAMERA_UNIQUE_ID=DEMO-CAM-001

# Password hashing strength.
# Default: 390000
PASSWORD_HASH_ITERATIONS=390000

# JWT for API access.
JWT_SECRET=change-me-in-production
JWT_ACCESS_TOKEN_TTL_SECONDS=3600

# Optional DB table name for vehicle telemetry config
# Use this when migrating legacy table names.
# Default: configuracion_mavlink
VEHICLE_TELEMETRY_CONFIG_TABLE=configuracion_mavlink

# Local ARCOM GeoPackage used for mining concession queries.
# Default: /home/robiotec/ARCOM/arcom_catastro.gpkg
ARCOM_GPKG_PATH=/home/robiotec/ARCOM/arcom_catastro.gpkg

# Maximum number of mining concessions returned to the map per viewport request.
# Default: 120
ARCOM_MAX_FEATURES_PER_REQUEST=120

# ============================================================
# MEDIAMTX PROTOCOL PORTS
# ============================================================
# These ports must match the MediaMTX server configuration

# WebRTC streaming port
# Default: 9998
MEDIAMTX_WEBRTC_PORT=9998

# RTSP streaming port
# Default: 8654
MEDIAMTX_RTSP_PORT=8654

# HLS streaming port
# Default: 8988
MEDIAMTX_HLS_PORT=8988

# RTMP streaming port
# Default: 1936
MEDIAMTX_RTMP_PORT=1936

# SRT streaming port
# Default: 8991
MEDIAMTX_SRT_PORT=8991

# ============================================================
# WEB APPLICATION CONFIGURATION
# ============================================================

# Session cookie name
# Default: robiotec_session
WEB_SESSION_COOKIE_NAME=robiotec_session

# Session encryption secret (sensitive)
# Should be a strong random string for production
# Default: robiotec-dev-session-secret
WEB_SESSION_SECRET=robiotec-dev-session-secret

# Session max age in seconds (8 hours)
# Default: 28800
WEB_SESSION_MAX_AGE_SECONDS=28800

# Web server bind hostname (0.0.0.0 = all interfaces)
# Default: 0.0.0.0
WEB_HOST=0.0.0.0

# Web server bind port
# Default: 8001
WEB_PORT=8001

# ============================================================
# VIEWER CACHE CONFIGURATION
# ============================================================

# Maximum age of cached viewer HTML in seconds (24 hours)
# Default: 86400
VIEWER_CACHE_MAX_AGE_SECONDS=86400

# ============================================================
# DJI TELEMETRY MQTT CONFIGURATION
# ============================================================

# MQTT broker hostname or IP for DJI telemetry
# Default: 192.168.1.92
DJI_MQTT_BROKER=192.168.1.92

# MQTT broker port
# Default: 1883
DJI_MQTT_PORT=1883

# ============================================================
# CROPS SSH CONFIGURATION
# ============================================================

# Host remoto donde está el manifest de crops (IP o hostname)
# Default: 100.93.62.24
CROPS_SSH_HOST=100.93.62.24

# Usuario SSH para conectarse al host remoto
# Default: robiotec
CROPS_SSH_USER=robiotec

# Puerto SSH del host remoto
# Default: 22
CROPS_SSH_PORT=22

# Ruta a la llave privada SSH. Dejar vacío para usar el agente SSH del sistema.
# Default: (vacío)
CROPS_SSH_KEY_PATH=

# Ruta completa al archivo manifest.jsonl en el servidor remoto
CROPS_REMOTE_MANIFEST_PATH=/home/robiotec/Documents/VICTOR/Object_Recognition/unified/results/manifest.jsonl
