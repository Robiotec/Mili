# Copy this file to .env and fill in the values before running the app.

# ── General ──
PUBLIC_HOST=
API_HOST=0.0.0.0
API_PORT=8004
API_RELOAD=false
CORS_EXTRA_ORIGINS=
API_LOG_FILE=/home/robiotec/SVI/servicios/logs/apicentral.log

# ── JWT ──
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PLAYBACK_TOKEN_EXPIRE_MINUTES=60

# ── MediaMTX ──
MEDIAMTX_API_URL=http://127.0.0.1:9998
MEDIAMTX_API_USERNAME=
MEDIAMTX_API_PASSWORD=
MEDIAMTX_WEBRTC_PORT=8989
MEDIAMTX_HLS_PORT=8988

# ── airplanes.live (cobertura Ecuador) ──
AIRPLANES_LAT=-1.8
AIRPLANES_LON=-78.2
AIRPLANES_RADIUS_NM=250
AIRPLANES_LAT2=-5.5
AIRPLANES_LON2=-78.5
AIRPLANES_RADIUS_NM2=200

# ── PostgreSQL ──
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=apicentral
DB_USER=apicentraluser
DB_PASSWORD=
DB_MIN_SIZE=1
DB_MAX_SIZE=10
DB_TIMEOUT=10
DB_CONNECT_TIMEOUT=5
