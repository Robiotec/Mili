# Copy this file to .env and fill in the values before running the app.

# ── General ──
PUBLIC_HOST=
API_PORT=8004
CORS_EXTRA_ORIGINS=

# ── JWT ──
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PLAYBACK_TOKEN_EXPIRE_MINUTES=60

# ── MediaMTX ──
MEDIAMTX_API_URL=http://127.0.0.1:9998
MEDIAMTX_API_USERNAME=
MEDIAMTX_API_PASSWORD=

# ── OpenSky Network - Bounding box (Ecuador defaults) ──
OPENSKY_LAMIN=-5.0
OPENSKY_LOMIN=-81.0
OPENSKY_LAMAX=2.0
OPENSKY_LOMAX=-75.0

# ── PostgreSQL ──
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=apicentral
DB_USER=apicentraluser
DB_PASSWORD=
DB_MIN_SIZE=1
DB_MAX_SIZE=10
DB_TIMEOUT=10
DB_CONNECT_TIMEOUT=5
